{
  "name": "rapidconstruct-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "perf": "next build && lhci autorun",
    "board": "node tools/board-server.js",
    "board:start": "nohup node tools/board-server.js > tools/board.log 2>&1 & echo $! > tools/board.pid && echo \"board running (pid $(cat tools/board.pid)) -> http://localhost:4300\"",
    "board:stop": "if [ -f tools/board.pid ]; then kill $(cat tools/board.pid) 2>/dev/null; rm -f tools/board.pid; echo 'board stopped'; else echo 'board not running'; fi"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "next-intl": "^4.13.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
